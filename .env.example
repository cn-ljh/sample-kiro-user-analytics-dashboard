# deploy.sh configuration
# Copy to .env and fill in your values

# AWS Region
AWS_REGION=us-east-1

# S3 path where Kiro stores user report data (bucket-name/prefix)
# The Glue Crawler scans: s3://<S3_DATA_PATH>/AWSLogs/<AccountId>/KiroLogs/user_report/<Region>/
S3_DATA_PATH=my-bucket/my-prefix

# VPC and Subnets (at least 2 subnets in different AZs for ALB)
VPC_ID=vpc-xxxxxxxx
SUBNET_IDS=subnet-aaa,subnet-bbb

# Domain name and HTTPS certificate
DOMAIN_NAME=kiro.example.com
CERTIFICATE_ARN=arn:aws:acm:us-east-1:123456789012:certificate/xxxxxxxx

# Route53 Hosted Zone ID (optional, leave empty to manage DNS manually)
HOSTED_ZONE_ID=

# IAM Identity Center Identity Store ID (optional, for resolving usernames)
IDENTITY_STORE_ID=
